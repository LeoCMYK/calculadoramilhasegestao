# ============================================================
# Variáveis de ambiente — cadastre estes valores na Vercel
# (Project Settings > Environment Variables). NÃO comite segredos.
# ============================================================

# --- RD Station (Conversions API) ---
# Token público da API: RD Station > Integrações > Token de API (token público).
RD_TOKEN=
# Nome do evento de conversão que aparecerá no RD.
RD_CONVERSION_IDENTIFIER=calculadora-milhas

# --- Mautic (submissão de formulário) ---
# URL base da sua instância, sem barra no final. Ex.: https://mkt.suaempresa.com.br
MAUTIC_BASE_URL=
# ID numérico do formulário (Mautic > Forms > seu form > a URL/edição mostra o ID).
MAUTIC_FORM_ID=
# Alias do formulário (Mautic > Forms > coluna "Alias").
MAUTIC_FORM_NAME=
